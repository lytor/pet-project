# Автоматически сгенерировано Ansible {{ ansible_date_time.iso8601 }}

# PostgreSQL
POSTGRES_DB=myapp
POSTGRES_USER=user
POSTGRES_PASSWORD={{ lookup('file', 'secrets/db_password.txt') }}

# Redis
REDIS_PASSWORD={{ lookup('file', 'secrets/redis_password.txt') }}

# Приложение
APP_ENV=production
APP_SECRET={{ lookup('password', '/dev/null length=32 chars=ascii_letters,digits') }}

# Мониторинг (опционально)
GRAFANA_ADMIN_PASSWORD=admin  # Изменить при первом входе!